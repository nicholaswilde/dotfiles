set -e
set -o pipefail

# set variables
declare -r TRUE=0
declare -r FALSE=1
declare -r PASSWD_FILE=/etc/passwd

# https://en.wikipedia.org/wiki/ANSI_escape_code
function black() { printf "\e[30m"; }
function red() { printf "\e[31m"; }
function green() { printf "\e[32m"; }
function yellow() { printf "\e[33m"; }
function blue() { printf "\e[34m"; }
function magenta() { printf "\e[35m"; }
function cyan() { printf "\e[36m"; }
function white() { printf "\e[37m"; }
function gray() { printf "\e[90m"; }
function bold() { printf "\e[1m"; }
function clr() { printf "\e[0m"; }
function brightred() { printf "\e[91m"; }
function brightgreen() { printf "\e[92m"; }
function brightyellow() { printf "\e[93m"; }
function brightblue() { printf "\e[94m"; }
function brightmagenta() { printf "\e[95m"; }
function brightcyan() { printf "\e[96m"; }
function brightwhite() { printf "\e[97m"; }

##################################################################
# Purpose: Converts a string to lower case
# Arguments:
#   $1 -> String to convert to lower case
# https://bash.cyberciti.biz/guide/Shell_functions_library
##################################################################
function to_lower() { tr '[:upper:]' '[:lower:]'<<<"${*}"; }

function to_upper() { tr '[:lower:]' '[:upper:]'<<<"${*}"; }

##################################################################
# Purpose: Return true if script is executed by the root user
# Arguments: none
# Return: True or False
# https://bash.cyberciti.biz/guide/Shell_functions_library
##################################################################
function is_root() { [ "$(id -u)" -eq 0 ] && return $TRUE || return $FALSE; }

##################################################################
# Purpose: Return true $user exits in /etc/passwd
# Arguments: $1 (username) -> Username to check in /etc/passwd
# Return: True or False
# https://bash.cyberciti.biz/guide/Shell_functions_library
##################################################################
function is_user_exits() { grep -q "^${1}" $PASSWD_FILE && return $TRUE || return $FALSE; }

# Check is variable is null
function is_null() { [ -z "$1" ]; }

# Check if variable is set
# Returns false if empty
function is_set() { [ -n "${1}" ]; }

# Check if directory exists
function dir_exists() { [ -d "${1}" ]; }

# Check if file exists
function file_exists() { [ -f "${1}" ]; }

# Check if command exists
function command_exists() { command -v "${1}" &> /dev/null; }

# Strip the file extension: foo.tar.gz -> foo
function strip_ext() { echo "${1%%.*}"; }

function get_last() { echo "${1: -1}"; }

function trim_last() { echo "${1::-1}"; }

function get_first() { echo "${1::1}"; }

function trim_first() { echo "${1: 1}"; }

##################################################################
# Purpose: Checks if the first argument contains the second
# Arguments:
#   $1 -> Long string to search in
#   $2 -> String to search for
# https://stackoverflow.com/a/229606/1061279
##################################################################
function contains() { [[ "$1" == *"$2"* ]]; }

##################################################################
# Purpose: Generate a random string of a certain length
# Arguments:
#   $1 Default:64 -> Length of string to return
##################################################################
function random() { < /dev/urandom tr -dc 'a-zA-Z0-9' | fold -w "${1:-64}" | head -n 1; }
